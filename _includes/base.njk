<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }} | log.meany.xyz</title>
    <link rel="alternate" type="application/atom+xml" title="Log Feed" href="/feed.xml">
    <link rel="stylesheet" href="/css/style.css">
  </head>
  <body>
    <a class="skip-link" href="#maincontent">Skip to main content</a>
    <header class="site-header">
      <div class="shell">
        <nav aria-label="Primary">
          <a href="/" class="brand">root</a>
          <a href="/tags/">tags</a>
          <a href="/feed.xml">atom</a>
        </nav>
      </div>
    </header>
    <main id="maincontent" tabindex="-1" class="shell">
      {{ content | safe }}
    </main>
    <footer class="shell site-footer">
      <p>Static output. Git history is the source log.</p>
    </footer>
  </body>
</html>