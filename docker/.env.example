# GitHub repository config
GITHUB_OWNER=your-github-username
GITHUB_REPO=log.meany.xyz
GITHUB_TOKEN=ghp_your_fine_grained_personal_access_token

# Workflow and artifact settings
WORKFLOW_FILE=build.yml
ARTIFACT_NAME=site
BRANCH=main

# Polling behavior
POLL_INTERVAL_SECONDS=120

# Container paths (usually no need to change)
SITE_DIR=/site
STATE_DIR=/state
WORK_DIR=/tmp/work
